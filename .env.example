# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=care_assist
MYSQL_USER=care
MYSQL_PASSWORD=carepass

# App
DATABASE_URL=mysql+aiomysql://care:carepass@localhost:3306/care_assist
REDIS_URL=redis://localhost:6379
SECRET_KEY=replace-with-random-secret-in-production

# WeChat Mini Program
WECHAT_APPID=your-app-id
WECHAT_SECRET=your-app-secret

# WeChat subscription message template IDs (one per reminder type)
REMINDER_MEDICATION_TEMPLATE_ID=
REMINDER_VACCINE_TEMPLATE_ID=
REMINDER_CHECKUP_TEMPLATE_ID=
REMINDER_REVIEW_TEMPLATE_ID=

# AI Provider (default: kimi-code)
DEFAULT_AI_PROVIDER=kimi-code
KIMI_CODE_API_KEY=
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODE_MODEL=kimi-k2.6

# OCR Provider (default: kimi)
OCR_PROVIDER=kimi
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=
MOONSHOT_API_KEY=

# OSS (optional for local dev)
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
