# Database
DATABASE_URL=mysql+aiomysql://care:carepass@localhost:3306/care_assist

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=replace-with-random-secret-in-production

# WeChat MiniProgram
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# OSS (Object Storage Service)
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Sentry (optional)
SENTRY_DSN=

# Environment: development | staging | production
ENVIRONMENT=development

# Debug mode
DEBUG=false

# Logging configuration
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file directory and base filename (rotating files will be created under this path)
LOG_FILE_PATH=logs/care-assist.log

# Log format: standard (human-readable) | json (structured, for ELK/Loki)
LOG_FORMAT=standard

# AI Provider configuration
# Provider name: kimi-code (default)
DEFAULT_AI_PROVIDER=kimi-code
FALLBACK_AI_PROVIDERS=[]

# Kimi Code provider (Anthropic protocol via https://api.kimi.com/coding)
# DO NOT commit the real API key to git; keep it in backend/.env only.
KIMI_CODE_API_KEY=your-kimi-code-api-key
KIMI_CODE_BASE_URL=https://api.kimi.com/coding
KIMI_CODE_MODEL=kimi-k2.6
KIMI_CODE_TIMEOUT=60.0

# OCR Provider configuration
# Provider name: mock (default) | baidu | tencent
OCR_PROVIDER=mock
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key
TENCENT_OCR_SECRET_ID=your-tencent-ocr-secret-id
TENCENT_OCR_SECRET_KEY=your-tencent-ocr-secret-key
