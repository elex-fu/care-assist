<view class="container">
  <view class="form-body">
    <view class="form-row">
      <text class="form-label">药品名称 *</text>
      <input class="form-input" placeholder="如：氨氯地平" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-row">
      <text class="form-label">剂量 *</text>
      <input class="form-input" placeholder="如：5mg" value="{{dosage}}" bindinput="onDosageInput" />
    </view>

    <view class="form-row">
      <text class="form-label">服用频次</text>
      <picker mode="selector" range="{{['每日1次', '每日2次', '每日3次', '每周1次', '按需']}}" value="{{frequencyIndex}}" bindchange="onFrequencyChange">
        <view class="form-picker">
          <text>{{frequency}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row" wx:for="{{timeSlots}}" wx:key="*this">
      <text class="form-label">服药时间 {{index + 1}}</text>
      <picker mode="time" value="{{item}}" data-idx="{{index}}" bindchange="onTimeChange">
        <view class="form-picker">
          <text>{{item}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row">
      <text class="form-label">开始日期</text>
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="form-picker">
          <text>{{startDate}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row">
      <text class="form-label">结束日期（可选）</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="form-picker">
          <text>{{endDate || '请选择'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="如：早餐后服用" value="{{notes}}" bindinput="onNotesInput" />
    </view>

    <view class="form-row" wx:if="{{editId}}">
      <text class="form-label">状态</text>
      <picker mode="selector" range="{{statusLabels}}" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="form-picker">
          <text>{{statusLabels[statusIndex]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="submit-bar">
    <button class="btn-submit" bindtap="submit">保存</button>
  </view>
</view>
