.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #EFF6FF 0%, #FFFFFF 100%);
  padding: 32px;
}

.logo {
  text-align: center;
  margin-bottom: 48px;
}

.logo-text {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 8px;
}

.logo-sub {
  display: block;
  font-size: 16px;
  color: #94A3B8;
}

.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20px;
  padding: 32px 24px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.title {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8px;
  text-align: center;
}

.desc {
  display: block;
  font-size: 14px;
  color: #94A3B8;
  margin-bottom: 24px;
  text-align: center;
}

.input {
  width: 100%;
  height: 48px;
  background: #F8FAFC;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  color: #1E293B;
  margin-bottom: 16px;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 48px;
  background: #2563EB;
  color: #FFFFFF;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}