<view class="container">
  <view class="header">
    <text class="header-title">{{memberName}}的报告</text>
    <text class="header-count" wx:if="{{reports.length}}">共 {{reports.length}} 份</text>
  </view>

  <view class="report-list" wx:if="{{reports.length}}">
    <report-card
      wx:for="{{reports}}"
      wx:key="id"
      report="{{item}}"
      data-id="{{item.id}}"
      bindtap="goToReportDetail"
    />
  </view>

  <empty-state
    wx:if="{{!loading && !reports.length}}"
    icon="📄"
    title="暂无报告"
    subtitle="上传检查报告，AI 自动识别指标"
    actionText="去上传"
    bind:action="goToUpload"
  />

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
