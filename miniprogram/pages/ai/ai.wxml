<view class="container {{elderMode ? 'elder-mode' : ''}}">
  <!-- Top Bar: Member Selector + History -->
  <view class="top-bar">
    <scroll-view class="member-selector" scroll-x="true" enable-flex="true">
      <view
        class="member-chip {{currentMemberId === item.id ? 'active' : ''}}"
        wx:for="{{members}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectMember"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
    <view class="history-btn" bindtap="toggleHistory">
      <text>历史</text>
    </view>
  </view>

  <!-- Chat Messages -->
  <scroll-view class="chat-scroll" scroll-y="true" scroll-into-view="msg-{{messages.length - 1}}">
    <view class="message-list">
      <!-- Welcome -->
      <view class="message system" wx:if="{{!messages.length}}">
        <view class="bubble system-bubble">
          <text class="bubble-text">你好！我是家庭健康助手 AI，可以帮你分析健康指标、解读报告、提供建议。请直接输入问题或点击下方快速提问。</text>
        </view>
      </view>

      <view
        class="message {{item.role === 'user' ? 'user' : 'assistant'}}"
        wx:for="{{messages}}"
        wx:key="index"
        id="msg-{{index}}"
      >
        <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'assistant-bubble'}}">
          <!-- Structured assistant message -->
          <block wx:if="{{item.role === 'assistant' && item._blocks && item._blocks.length}}">
            <view class="struct-block" wx:for="{{item._blocks}}" wx:for-item="block" wx:key="index">
              <!-- Text block -->
              <text class="bubble-text" wx:if="{{block.type === 'text'}}">{{block.content}}</text>

              <!-- Indicator table block -->
              <view class="ai-indicator-table" wx:if="{{block.type === 'indicator_table'}}">
                <view class="ai-indicator-row" wx:for="{{block.rows}}" wx:for-item="row" wx:key="name">
                  <text class="ai-indicator-name">{{row.name}}</text>
                  <view class="ai-indicator-value-wrap">
                    <text class="ai-indicator-value">{{row.value}}</text>
                    <text class="ai-indicator-unit" wx:if="{{row.unit}}">{{row.unit}}</text>
                    <text class="ai-indicator-status {{row.status === '↑' || row.status === '偏高' || row.status === '高' ? 'high' : row.status === '↓' || row.status === '偏低' || row.status === '低' ? 'low' : ''}}">{{row.status}}</text>
                  </view>
                </view>
              </view>

              <!-- Question list block -->
              <view class="ai-question-card" wx:if="{{block.type === 'question_list'}}">
                <text class="ai-question-title">建议问医生的问题</text>
                <view class="ai-question-item" wx:for="{{block.items}}" wx:for-item="q" wx:key="num">
                  <text class="ai-question-num">{{q.num}}</text>
                  <text class="ai-question-text">{{q.text}}</text>
                </view>
              </view>

              <!-- Actions block -->
              <view class="ai-action-row" wx:if="{{block.type === 'actions'}}">
                <view class="ai-action-btn" wx:for="{{block.items}}" wx:for-item="act" wx:key="action" data-action="{{act.action}}" bindtap="onAiAction">
                  <text>{{act.label}}</text>
                </view>
              </view>
            </view>
          </block>

          <!-- Plain text fallback -->
          <text class="bubble-text" wx:elif="{{item.content}}">{{item.content}}</text>

          <view class="typing" wx:if="{{!item.content && item.role === 'assistant'}}">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Quick Questions -->
  <view class="quick-questions" wx:if="{{!loading && messages.length < 2}}">
    <view
      class="q-chip"
      wx:for="{{quickQuestions}}"
      wx:key="*this"
      data-q="{{item}}"
      bindtap="onQuickQuestion"
    >
      <text>{{item}}</text>
    </view>
  </view>

  <!-- Input Bar -->
  <view class="input-bar">
    <input
      class="chat-input"
      placeholder="输入问题..."
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSendTap"
    />
    <view class="send-btn {{inputValue.trim() ? 'active' : ''}}" bindtap="onSendTap">
      <text>发送</text>
    </view>
  </view>

  <!-- History Popup -->
  <view class="popup-overlay" wx:if="{{showHistory}}" bindtap="closeHistory">
    <view class="popup-sheet" catchtap="preventClose">
      <view class="popup-header">
        <text class="popup-title">历史对话</text>
        <text class="popup-close" bindtap="closeHistory">✕</text>
      </view>
      <view class="popup-body">
        <view class="conv-item" wx:for="{{conversations}}" wx:key="id" data-id="{{item.id}}" bindtap="loadConversation">
          <text class="conv-preview">{{item.last_message_preview || '无消息'}}</text>
          <text class="conv-count">{{item.message_count}} 条</text>
        </view>
        <empty-state
          wx:if="{{!conversations.length}}"
          title="暂无历史对话"
        />
      </view>
      <view class="popup-footer">
        <button class="btn-new" bindtap="startNewConversation">新建对话</button>
      </view>
    </view>
  </view>
</view>
