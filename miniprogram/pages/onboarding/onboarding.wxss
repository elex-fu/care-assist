.container {
  height: 100vh;
  background: linear-gradient(180deg, #EFF6FF 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  position: relative;
}

.swiper {
  flex: 1;
  width: 100%;
}

.step {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 32px;
  box-sizing: border-box;
}

.illustration {
  width: 120px;
  height: 120px;
  border-radius: 60px;
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32px;
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.2);
}

.illustration-icon {
  font-size: 56px;
}

.step-title {
  font-size: 24px;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12px;
  text-align: center;
}

.step-desc {
  font-size: 15px;
  color: #64748B;
  line-height: 1.6;
  text-align: center;
  max-width: 280px;
}

.step-action {
  margin-top: 40px;
  width: 100%;
  max-width: 280px;
}

.btn-primary {
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  border-radius: 12px;
  padding: 14px 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary text {
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
}

.dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding-bottom: 48px;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 4px;
  background: #CBD5E1;
  transition: all 0.3s;
}

.dot.active {
  width: 20px;
  background: #2563EB;
}

.skip-wrap {
  position: absolute;
  top: 48px;
  right: 24px;
}

.skip {
  font-size: 14px;
  color: #94A3B8;
  padding: 8px;
}
