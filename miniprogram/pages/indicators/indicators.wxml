<view class="container {{elderMode ? 'elder-mode' : ''}}">
  <!-- Member Selector -->
  <scroll-view class="member-selector" scroll-x="true" enable-flex="true">
    <view
      class="member-chip {{currentMemberId === item.id ? 'active' : ''}}"
      wx:for="{{members}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="selectMember"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- Indicator List -->
  <view class="indicator-list" wx:if="{{!loading && indicators.length}}">
    <indicator-row
      wx:for="{{indicators}}"
      wx:key="id"
      indicator="{{item}}"
      data-key="{{item.indicator_key}}"
      data-name="{{item.indicator_name}}"
      bindtap="showTrend"
    />
  </view>

  <!-- Empty State -->
  <empty-state
    wx:if="{{!loading && !indicators.length}}"
    icon="📊"
    title="还没有记录"
    subtitle="点击右下角按钮添加第一条指标"
  />

  <!-- Skeleton Loading -->
  <view class="skeleton-wrap" wx:if="{{loading}}" style="padding: 12px 16px;">
    <view style="white-space: nowrap; margin-bottom: 12px;">
      <view class="skeleton-chip" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>
    <view class="skeleton-row" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
  </view>

  <!-- Floating Actions -->
  <view class="fab-bar" wx:if="{{!showAddForm}}">
    <view class="fab-secondary" bindtap="goToBatch">
      <text class="fab-secondary-text">批量</text>
    </view>
    <view class="fab" bindtap="openAddForm">
      <text class="fab-icon">+</text>
    </view>
  </view>

  <!-- Add Form Overlay -->
  <view class="form-overlay" wx:if="{{showAddForm}}" bindtap="closeAddForm">
    <view class="form-sheet" catchtap="preventClose">
      <view class="form-header">
        <text class="form-title">添加指标</text>
        <text class="form-close" bindtap="closeAddForm">✕</text>
      </view>

      <view class="form-body">
        <view class="form-row">
          <text class="form-label">指标名称</text>
          <picker mode="selector" range="{{['收缩压', '舒张压', '心率', '空腹血糖', '糖化血红蛋白', '体重', '身高', '体温']}}" value="{{indicatorIndex}}" bindchange="onIndicatorChange">
            <view class="form-picker">
              <text>{{['收缩压', '舒张压', '心率', '空腹血糖', '糖化血红蛋白', '体重', '身高', '体温'][indicatorIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-row">
          <text class="form-label">数值 ({{indicatorUnit}})</text>
          <input class="form-input" type="digit" placeholder="请输入数值" value="{{indicatorValue}}" bindinput="onValueInput" />
        </view>

        <view class="form-row">
          <text class="form-label">记录日期</text>
          <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
            <view class="form-picker">
              <text>{{recordDate}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="form-footer">
        <button class="btn-submit" bindtap="submitIndicator">保存</button>
      </view>
    </view>
  </view>

  <!-- Trend Popup -->
  <view class="popup-overlay" wx:if="{{showTrendPopup}}" bindtap="closeTrendPopup">
    <view class="popup-sheet" catchtap="preventClose">
      <view class="popup-header">
        <text class="popup-title">{{trendData.indicator_name}} 趋势</text>
        <text class="popup-close" bindtap="closeTrendPopup">✕</text>
      </view>

      <view class="popup-body" wx:if="{{trendData}}">
        <view class="trend-current" wx:if="{{trendData.current}}">
          <text class="trend-label">最新</text>
          <view class="trend-value-row">
            <text class="trend-value">{{trendData.current.value}}</text>
            <text class="trend-unit">{{trendData.unit}}</text>
            <view class="trend-status" style="background: {{getStatusColor(trendData.current.status)}};">
              <text>{{getStatusLabel(trendData.current.status)}}</text>
            </view>
          </view>
          <text class="trend-date">{{formatDateLabel(trendData.current.record_date)}}</text>
        </view>

        <view class="trend-previous" wx:if="{{trendData.previous}}">
          <text class="trend-label">上次</text>
          <view class="trend-value-row">
            <text class="trend-value">{{trendData.previous.value}}</text>
            <text class="trend-unit">{{trendData.unit}}</text>
            <view class="trend-status" style="background: {{getStatusColor(trendData.previous.status)}};">
              <text>{{getStatusLabel(trendData.previous.status)}}</text>
            </view>
          </view>
          <text class="trend-date">{{formatDateLabel(trendData.previous.record_date)}}</text>
        </view>

        <view class="trend-summary" wx:if="{{trendData.trend}}">
          <text class="trend-arrow">{{getTrendArrow(trendData.trend.direction)}}</text>
          <text class="trend-evaluation">{{getTrendLabel(trendData.trend.evaluation)}}</text>
        </view>
      </view>

      <view class="popup-empty" wx:else>
        <text>暂无趋势数据</text>
      </view>
    </view>
  </view>
</view>
