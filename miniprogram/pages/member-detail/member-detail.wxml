<view class="container {{elderMode ? 'elder-mode' : ''}}">
  <!-- Header -->
  <member-card
    wx:if="{{member}}"
    member="{{member}}"
    variant="header"
  >
    <view slot="meta" class="meta-row">
      <text class="meta">{{getMemberTypeLabel(member.type)}}</text>
      <text class="meta-dot">·</text>
      <text class="meta">{{member.gender === 'male' ? '男' : '女'}}</text>
      <text class="meta-dot" wx:if="{{member.blood_type}}">·</text>
      <text class="meta" wx:if="{{member.blood_type}}">血型 {{member.blood_type}}</text>
    </view>
    <text slot="role" class="role-tag">{{member.role === 'creator' ? '家庭创建者' : '家庭成员'}}</text>
    <view slot="actions" class="header-links">
      <view class="header-link" bindtap="goToHospitals">
        <text>🏥 住院记录 ›</text>
      </view>
      <view class="header-link" bindtap="goToVaccines">
        <text>💉 疫苗记录 ›</text>
      </view>
      <view class="header-link" bindtap="goToMedications">
        <text>💊 用药管理 ›</text>
      </view>
    </view>
  </member-card>

  <!-- Tabs -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'timeline' ? 'active' : ''}}" data-tab="timeline" bindtap="switchTab">
      <text>时间轴</text>
    </view>
    <view class="tab {{activeTab === 'indicators' ? 'active' : ''}}" data-tab="indicators" bindtap="switchTab">
      <text>指标</text>
    </view>
    <view class="tab {{activeTab === 'reports' ? 'active' : ''}}" data-tab="reports" bindtap="switchTab">
      <text>报告</text>
    </view>
    <view class="tab {{activeTab === 'ai' ? 'active' : ''}}" data-tab="ai" bindtap="switchTab">
      <text>AI</text>
    </view>
  </view>

  <!-- Timeline Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'timeline'}}">
    <view class="add-event-bar">
      <view class="add-event-btn" bindtap="toggleEventForm">
        <text>{{showEventForm ? '取消' : '+ 添加事件'}}</text>
      </view>
    </view>

    <view class="event-form" wx:if="{{showEventForm}}">
      <view class="form-group">
        <text class="form-label">类型</text>
        <picker bindchange="onEventTypeChange" value="{{eventTypes.indexOf(eventForm.type)}}" range="{{['就诊', '检验', '用药', '症状', '住院', '疫苗', '体检', '里程碑']}}">
          <view class="form-picker">
            {{getEventTypeLabel(eventForm.type)}}
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">日期 *</text>
        <picker mode="date" value="{{eventForm.event_date}}" data-field="event_date" bindchange="onEventDateChange">
          <view class="form-picker">{{eventForm.event_date || '请选择日期'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">医院</text>
        <input class="form-input" placeholder="请输入医院" data-field="hospital" bindinput="onEventInput" value="{{eventForm.hospital}}" />
      </view>
      <view class="form-group">
        <text class="form-label">诊断</text>
        <input class="form-input" placeholder="请输入诊断" data-field="diagnosis" bindinput="onEventInput" value="{{eventForm.diagnosis}}" />
      </view>
      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="请输入备注" data-field="notes" bindinput="onEventInput" value="{{eventForm.notes}}" />
      </view>
      <button class="form-submit" bindtap="submitEvent">保存</button>
    </view>

    <view class="timeline" wx:if="{{events.length}}">
      <timeline-node wx:for="{{events}}" wx:key="id" event="{{item}}" bind:tap="onTimelineCardTap" />
    </view>
    <empty-state wx:else title="暂无时间轴记录" subtitle="指标和报告会自动生成时间轴" />
  </view>

  <!-- Indicators Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'indicators'}}">
    <view class="indicator-list" wx:if="{{indicators.length}}">
      <indicator-row wx:for="{{indicators}}" wx:key="id" indicator="{{item}}" data-id="{{item.id}}" data-key="{{item.indicator_key}}" data-name="{{item.indicator_name}}" data-unit="{{item.unit}}" bindtap="onIndicatorTap" />
    </view>
    <empty-state wx:else title="暂无指标记录" subtitle="去添加指标 ›" bind:action="goToIndicatorsPage" />
  </view>

  <!-- Reports Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'reports'}}">
    <view class="section-header" wx:if="{{reports.length}}">
      <text class="section-title">最近报告</text>
      <text class="section-link" bindtap="goToReportsPage">查看全部 ›</text>
    </view>
    <view class="report-list" wx:if="{{reports.length}}">
      <report-card wx:for="{{reports}}" wx:key="id" report="{{item}}" data-id="{{item.id}}" bindtap="goToReportDetail" />
    </view>
    <empty-state wx:else title="暂无报告" subtitle="去上传报告 ›" actionText="去上传报告" bind:action="goToUploadPage" />
  </view>

  <!-- Abnormal Guide -->
  <abnormal-guide
    visible="{{showAbnormalGuide}}"
    indicator="{{selectedIndicator}}"
    bind:close="onGuideClose"
    bind:action="onGuideAction"
  />

  <!-- AI Tab -->
  <view class="tab-content ai-tab" wx:if="{{activeTab === 'ai'}}">
    <view class="ai-chat">
      <view class="ai-message-list">
        <view class="ai-message {{item.role === 'user' ? 'user' : 'assistant'}}" wx:for="{{aiMessages}}" wx:key="index">
          <view class="ai-bubble {{item.role === 'user' ? 'user-bubble' : 'assistant-bubble'}}">
            <!-- Structured assistant message -->
            <block wx:if="{{item.role === 'assistant' && item._blocks && item._blocks.length}}">
              <view class="struct-block" wx:for="{{item._blocks}}" wx:for-item="block" wx:key="index">
                <text class="bubble-text" wx:if="{{block.type === 'text'}}">{{block.content}}</text>
                <view class="ai-indicator-table" wx:if="{{block.type === 'indicator_table'}}">
                  <view class="ai-indicator-row" wx:for="{{block.rows}}" wx:for-item="row" wx:key="name">
                    <text class="ai-indicator-name">{{row.name}}</text>
                    <view class="ai-indicator-value-wrap">
                      <text class="ai-indicator-value">{{row.value}}</text>
                      <text class="ai-indicator-unit" wx:if="{{row.unit}}">{{row.unit}}</text>
                      <text class="ai-indicator-status {{row.status === '↑' || row.status === '偏高' || row.status === '高' ? 'high' : row.status === '↓' || row.status === '偏低' || row.status === '低' ? 'low' : ''}}">{{row.status}}</text>
                    </view>
                  </view>
                </view>
                <view class="ai-question-card" wx:if="{{block.type === 'question_list'}}">
                  <text class="ai-question-title">建议问医生的问题</text>
                  <view class="ai-question-item" wx:for="{{block.items}}" wx:for-item="q" wx:key="num">
                    <text class="ai-question-num">{{q.num}}</text>
                    <text class="ai-question-text">{{q.text}}</text>
                  </view>
                </view>
                <view class="ai-action-row" wx:if="{{block.type === 'actions'}}">
                  <view class="ai-action-btn" wx:for="{{block.items}}" wx:for-item="act" wx:key="action" data-action="{{act.action}}" bindtap="onAiAction">
                    <text>{{act.label}}</text>
                  </view>
                </view>
              </view>
            </block>
            <!-- Plain text fallback -->
            <text wx:elif="{{item.content}}">{{item.content}}</text>
          </view>
        </view>
        <view class="ai-message assistant" wx:if="{{aiLoading}}">
          <view class="ai-bubble assistant-bubble loading-bubble">
            <view class="typing">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
          </view>
        </view>
        <view class="ai-welcome" wx:if="{{!aiMessages.length && !aiLoading}}">
          <text class="ai-welcome-text">向 AI 询问关于 {{member && member.name ? member.name : ''}} 的健康问题</text>
        </view>
      </view>
    </view>
    <view class="ai-input-bar">
      <input class="ai-input" placeholder="输入问题..." value="{{aiInput}}" bindinput="onAiInput" confirm-type="send" bindconfirm="sendAiMessage" />
      <view class="ai-send {{aiInput.trim() ? 'active' : ''}}" bindtap="sendAiMessage">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>
