.container {
  padding: 16px;
  background: #F8FAFC;
  min-height: 100vh;
}

.form-group {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #475569;
  margin-bottom: 8px;
}

.input {
  font-size: 16px;
  color: #1E293B;
  padding: 8px 0;
  border-bottom: 1px solid #E2E8F0;
}

.radio-item {
  margin-right: 16px;
  font-size: 14px;
  color: #475569;
}

.picker {
  font-size: 16px;
  color: #1E293B;
  padding: 8px 0;
  border-bottom: 1px solid #E2E8F0;
}

.submit-btn {
  margin-top: 24px;
  background: #2563EB;
  color: #FFFFFF;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
}
