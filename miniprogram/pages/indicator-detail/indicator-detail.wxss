.container {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 20px;
}

/* Header */
.page-header {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #FFFFFF;
}

.back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 28px;
  color: #1E293B;
  font-weight: 300;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #1E293B;
}

.spacer {
  width: 36px;
}

/* Hero Card */
.hero-card {
  background: #FFFFFF;
  margin: 16px;
  border-radius: 20px;
  padding: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.hero-main {
  flex: 1;
}

.hero-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-bottom: 10px;
}

.hero-value {
  font-size: 48px;
  font-weight: 700;
  color: #1E293B;
  line-height: 1;
}

.hero-unit {
  font-size: 16px;
  color: #94A3B8;
  font-weight: 500;
}

.hero-range-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}

.hero-range-label {
  font-size: 13px;
  color: #64748B;
}

.hero-range {
  font-size: 14px;
  color: #475569;
  font-weight: 500;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.hero-status {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  color: #FFFFFF;
}

.hero-status.normal {
  background: #10B981;
}

.hero-status.high,
.hero-status.low {
  background: #F59E0B;
}

.hero-status.critical {
  background: #EF4444;
}

.hero-date {
  font-size: 13px;
  color: #94A3B8;
}

/* Chart Section */
.chart-section {
  background: #FFFFFF;
  margin: 0 16px 16px;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
}

.section-count {
  font-size: 13px;
  color: #94A3B8;
}

.time-filters {
  display: flex;
  gap: 8px;
}

.time-filter {
  padding: 4px 10px;
  border-radius: 12px;
  background: #F1F5F9;
}

.time-filter text {
  font-size: 12px;
  color: #64748B;
  font-weight: 500;
}

.time-filter.active {
  background: #2563EB;
}

.time-filter.active text {
  color: #FFFFFF;
}

.chart-wrap {
  width: 100%;
  height: 200px;
}

.chart-canvas {
  width: 100%;
  height: 200px;
}

/* History Section */
.history-section {
  background: #FFFFFF;
  margin: 0 16px;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-row {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #F1F5F9;
}

.history-row:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.history-date {
  font-size: 14px;
  color: #1E293B;
  font-weight: 500;
}

.history-time {
  font-size: 12px;
  color: #94A3B8;
}

.history-center {
  flex: 1;
  text-align: center;
}

.history-value {
  font-size: 15px;
  font-weight: 600;
  color: #1E293B;
}

.history-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.history-status {
  padding: 4px 10px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 500;
}

.history-status.normal {
  background: #D1FAE5;
  color: #059669;
}

.history-status.high,
.history-status.low {
  background: #FEF3C7;
  color: #D97706;
}

.history-status.critical {
  background: #FECACA;
  color: #DC2626;
}

/* Footer Actions */
.footer-actions {
  padding: 16px;
}

.source-btn {
  height: 48px;
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.source-btn text {
  font-size: 15px;
  color: #FFFFFF;
  font-weight: 500;
}
