<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="family-name">{{family && family.name ? family.name : '加载中...'}}</view>
    <view class="header-actions">
      <view class="search-icon-btn" bindtap="goToSearch">
        <text class="search-icon-text">🔍</text>
      </view>
      <view class="add-icon-btn" bindtap="goToUpload">
        <text class="add-icon-text">+</text>
      </view>
    </view>
  </view>

  <!-- AI Daily Summary -->
  <view class="ai-banner" wx:if="{{aiSummary}}">
    <text class="ai-banner-text">{{aiSummary}}</text>
    <view class="refresh-btn" bindtap="loadDashboard">
      <text class="refresh-text">刷新</text>
    </view>
  </view>

  <!-- Member Cards Grid -->
  <view class="member-grid">
    <view
      class="member-card"
      wx:for="{{members}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToMemberDetail"
    >
      <member-card member="{{item}}" hospitalActive="{{!!hospitalMap[item.id]}}" />
    </view>

    <!-- Add Member Card -->
    <view class="member-card add-card" bindtap="goToAddMember">
      <view class="add-icon">+</view>
      <text class="add-text">添加成员</text>
    </view>
  </view>
</view>
