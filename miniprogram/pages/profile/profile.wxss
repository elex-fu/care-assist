.container {
  min-height: 100vh;
  background: #F8FAFC;
  padding: 16px;
  padding-bottom: 40px;
}

/* User Card (member-card component) */
.role-tag {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 10px;
  background: #F1F5F9;
  color: #64748B;
  font-size: 12px;
  font-weight: 500;
}

.role-tag.creator {
  background: #EFF6FF;
  color: #2563EB;
}

/* Section */
.section {
  margin-bottom: 20px;
}

.section-title {
  display: block;
  font-size: 14px;
  color: #94A3B8;
  font-weight: 500;
  margin-bottom: 8px;
  padding-left: 4px;
}

/* Family Card */
.family-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.family-name {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
}

.family-code {
  font-size: 13px;
  color: #64748B;
}

/* Menu */
.menu-list {
  background: #FFFFFF;
  border-radius: 12px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #F8FAFC;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger .menu-label {
  color: #EF4444;
}

.menu-icon {
  font-size: 18px;
  margin-right: 12px;
  width: 24px;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 15px;
  color: #1E293B;
}

.menu-arrow {
  color: #CBD5E1;
  font-size: 18px;
}

/* Member List */
.member-list {
  background: #FFFFFF;
  border-radius: 12px;
  overflow: hidden;
}

.member-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #F8FAFC;
}

.member-row:last-child {
  border-bottom: none;
}

.member-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.delete-btn {
  padding: 4px 12px;
  border-radius: 8px;
  background: #FEF2F2;
  color: #EF4444;
  font-size: 13px;
}

/* Version */
.version {
  text-align: center;
  padding: 24px 0;
  font-size: 12px;
  color: #CBD5E1;
}
