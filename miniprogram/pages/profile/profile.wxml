<view class="container {{elderMode ? 'elder-mode' : ''}}">
  <!-- User Card -->
  <member-card
    wx:if="{{member}}"
    member="{{member}}"
    variant="header"
  >
    <view slot="role" class="role-tag {{creator ? 'creator' : ''}}">
      <text>{{creator ? '创建者' : '成员'}}</text>
    </view>
  </member-card>

  <!-- Family Section -->
  <view class="section" wx:if="{{family}}">
    <text class="section-title">家庭信息</text>
    <view class="family-card">
      <text class="family-name">{{family.name}}</text>
      <text class="family-code">邀请码: {{family.invite_code}}</text>
    </view>
  </view>

  <!-- Actions -->
  <view class="section">
    <text class="section-title">功能</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToMemberAdd">
        <text class="menu-icon">👤</text>
        <text class="menu-label">添加成员</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToInvite">
        <text class="menu-icon">🔗</text>
        <text class="menu-label">邀请家人</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToReminders">
        <text class="menu-icon">⏰</text>
        <text class="menu-label">提醒管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMedications">
        <text class="menu-icon">💊</text>
        <text class="menu-label">用药管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToProfileEdit">
        <text class="menu-icon">✏️</text>
        <text class="menu-label">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToExport">
        <text class="menu-icon">📤</text>
        <text class="menu-label">数据导出</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="toggleElderMode">
        <text class="menu-icon">👴</text>
        <text class="menu-label">长辈模式</text>
        <text class="menu-arrow">{{elderMode ? '已开启' : '›'}}</text>
      </view>
    </view>
  </view>

  <!-- Members Management (Creator Only) -->
  <view class="section" wx:if="{{creator}}">
    <text class="section-title">成员管理</text>
    <view class="member-list">
      <view class="member-row" wx:for="{{members}}" wx:key="id">
        <view class="member-info" data-id="{{item.id}}" bindtap="goToMemberDetail">
          <member-card member="{{item}}" variant="list" />
        </view>
        <view
          class="delete-btn"
          wx:if="{{item.id !== (member && member.id)}}"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="deleteMember"
        >
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Logout -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item danger" bindtap="logout">
        <text class="menu-icon">🚪</text>
        <text class="menu-label">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Version -->
  <view class="version">
    <text>家庭健康助手 v{{version}}</text>
  </view>
</view>
