<view class="empty-state">
  <text class="empty-icon" wx:if="{{icon}}">{{icon}}</text>
  <text class="empty-title" wx:if="{{title}}">{{title}}</text>
  <text class="empty-subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>
  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">
    <text>{{actionText}}</text>
  </view>
</view>
