.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80px;
  gap: 10px;
}

.empty-icon {
  font-size: 48px;
}

.empty-title {
  font-size: 15px;
  color: #475569;
}

.empty-subtitle {
  font-size: 13px;
  color: #2563EB;
}

.empty-action {
  margin-top: 8px;
  padding: 8px 20px;
  background: #EFF6FF;
  border-radius: 20px;
}

.empty-action text {
  font-size: 14px;
  color: #2563EB;
  font-weight: 500;
}
