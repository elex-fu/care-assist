.ai-fab {
  position: fixed;
  right: 16px;
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background: #2563EB;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  display: flex;
