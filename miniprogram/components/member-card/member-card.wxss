/* ========== grid variant ========== */
.card {
  padding: 16px;
  background: #FFFFFF;
  border-radius: 16px;
}

.card-top {
  margin-bottom: 12px;
}

.avatar-wrap {
  position: relative;
  display: inline-block;
  width: 56px;
  height: 56px;
}

.avatar {
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 20px;
  font-weight: 600;
  color: #475569;
}

.status-badge {
  position: absolute;
  right: -4px;
  top: -4px;
  width: 22px;
  height: 22px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #FFFFFF;
}

.status-normal {
  background: #10B981;
}

.status-warning {
  background: #F59E0B;
}

.status-critical {
  background: #EF4444;
}

.status-hospital {
  background: #8B5CF6;
}

.card-body {
  margin-bottom: 8px;
}

.name {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 4px;
}

.type {
  font-size: 12px;
  color: #94A3B8;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-label {
  font-size: 12px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 10px;
  color: #FFFFFF;
}

.abnormal {
  font-size: 11px;
  color: #EF4444;
}

/* ========== list variant ========== */
.list-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #FFFFFF;
  border-radius: 12px;
}

.list-avatar {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  font-size: 14px;
  color: #475569;
  flex-shrink: 0;
}

.list-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.list-name {
  font-size: 15px;
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 2px;
}

.list-type {
  font-size: 12px;
  color: #94A3B8;
}

/* ========== header variant ========== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28px 16px 20px;
  background: #FFFFFF;
}

.header-avatar {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
}

.header-avatar text {
  font-size: 24px;
  font-weight: 600;
  color: #FFFFFF;
}

.header-name {
  font-size: 20px;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 6px;
}
