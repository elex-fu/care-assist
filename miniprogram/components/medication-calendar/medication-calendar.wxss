.calendar-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin: 12px 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.month-switcher {
  display: flex;
  align-items: center;
}

.switch-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14px;
  background: var(--primary-light);
  margin: 0 6px;
}

.switch-icon {
  font-size: 16px;
  color: var(--primary-dark);
  font-weight: 600;
}

.calendar-title {
  font-size: 15px;
  font-weight: 600;
}

.legend {
  display: flex;
  align-items: center;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-left: 8px;
  font-size: 11px;
  color: #64748B;
}

.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  margin-right: 4px;
}

.dot.complete { background: #10B981; }
.dot.partial { background: #F59E0B; }
.dot.missed { background: #EF4444; }

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  font-size: 12px;
  color: #94A3B8;
  margin-bottom: 8px;
}

.days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  row-gap: 8px;
}

.day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 44px;
  border-radius: 8px;
  font-size: 14px;
}

.day-num {
  line-height: 1;
}

.day-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  margin-top: 4px;
  background: currentColor;
}

.day.complete { color: #10B981; background: #ECFDF5; }
.day.partial { color: #F59E0B; background: #FEF3C7; }
.day.missed { color: #EF4444; background: #FEF2F2; }
.day.skipped { color: #94A3B8; background: #F1F5F9; }
.day.none { color: #1E293B; }
