<view class="container">
  <view class="report-header" wx:if="{{report}}">
    <view class="header-row">
      <view class="type-tag {{report.type}}">
        <text>{{getTypeLabel(report.type)}}</text>
      </view>
      <view class="status-badge {{getStatusClass(report.ocr_status)}}">
        <text>{{getStatusLabel(report.ocr_status)}}</text>
      </view>
    </view>
    <text class="hospital" wx:if="{{report.hospital}}">{{report.hospital}}</text>
    <text class="department" wx:if="{{report.department}}">{{report.department}}</text>
    <text class="report-date">{{report.report_date || '未填写日期'}}</text>
  </view>

  <view class="section" wx:if="{{report && report.images && report.images.length}}">
    <text class="section-title">原图</text>
    <view class="image-grid">
      <view class="image-item" wx:for="{{report.images}}" wx:key="index">
        <lazy-image src="{{item}}" width="100%" height="160px" radius="12px" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{report && report.extracted_indicators && report.extracted_indicators.length}}">
    <text class="section-title">识别指标</text>
    <view class="indicator-list">
      <indicator-row
        wx:for="{{report.extracted_indicators}}"
        wx:key="index"
        indicator="{{item}}"
        compact="{{true}}"
      />
    </view>
  </view>

  <view class="section" wx:if="{{report && report.ai_summary}}">
    <text class="section-title">AI 摘要</text>
    <view class="ai-summary-card">
      <text class="ai-summary-text">{{report.ai_summary}}</text>
    </view>
  </view>

  <empty-state
    wx:if="{{report && (!report.extracted_indicators || !report.extracted_indicators.length) && !report.ai_summary}}"
    title="暂无识别结果"
    subtitle="OCR 处理完成后将展示指标"
  />

  <view class="footer-actions" wx:if="{{report}}">
    <view class="delete-btn" bindtap="deleteReport">
      <text>删除报告</text>
    </view>
  </view>
</view>
