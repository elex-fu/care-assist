<view class="container">
  <view class="header-row">
    <text class="header-title">提醒管理</text>
    <view class="header-actions">
      <view class="settings-btn" bindtap="goToSettings">
        <text>⚙️</text>
      </view>
      <view class="add-btn" bindtap="goToAdd">
        <text class="add-btn-text">+ 新增</text>
      </view>
    </view>
  </view>

  <view class="filter-bar">
    <picker bindchange="onMemberChange" value="{{members.findIndex(m => m.id === memberId)}}" range="{{members}}" range-key="name">
      <view class="filter-picker">
        <text class="filter-text">{{members.find(m => m.id === memberId) ? members.find(m => m.id === memberId).name : '选择成员'}}</text>
        <text class="filter-arrow">▼</text>
      </view>
    </picker>
    <view class="status-filters">
      <view class="status-filter {{statusFilter === '' ? 'active' : ''}}" data-status="" bindtap="setStatusFilter">
        <text>全部</text>
      </view>
      <view class="status-filter {{statusFilter === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="setStatusFilter">
        <text>待处理</text>
      </view>
      <view class="status-filter {{statusFilter === 'completed' ? 'active' : ''}}" data-status="completed" bindtap="setStatusFilter">
        <text>已完成</text>
      </view>
      <view class="status-filter {{statusFilter === 'overdue' ? 'active' : ''}}" data-status="overdue" bindtap="setStatusFilter">
        <text>已逾期</text>
      </view>
    </view>
  </view>

  <view class="reminder-list" wx:if="{{reminders.length}}">
    <view class="reminder-card" wx:for="{{reminders}}" wx:key="id">
      <view class="card-main" data-id="{{item.id}}" bindtap="goToEdit">
        <view class="card-header">
          <text class="reminder-title">{{item.title}}</text>
          <view class="priority-tag {{item.priority}}">
            <text>{{getPriorityLabel(item.priority)}}</text>
          </view>
        </view>
        <text class="reminder-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="card-meta">
          <text class="type-tag">{{getTypeLabel(item.type)}}</text>
          <text class="meta-dot">·</text>
          <text class="meta-date">{{item.scheduled_date}}</text>
          <text class="meta-dot">·</text>
          <text class="status-text {{item.status}}">{{getStatusLabel(item.status)}}</text>
        </view>
      </view>
      <view class="complete-btn" wx:if="{{item.status !== 'completed'}}" data-id="{{item.id}}" bindtap="completeReminder">
        <text>完成</text>
      </view>
    </view>
  </view>

  <empty-state
    wx:else
    title="暂无提醒"
    actionText="添加提醒 +"
    bind:action="goToAdd"
  />
</view>
