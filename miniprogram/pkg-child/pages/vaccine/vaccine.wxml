<view class="container">
  <view class="header-row">
    <view class="header-title-wrap">
      <text class="header-title">疫苗记录</text>
      <view class="summary-badges" wx:if="{{vaccines.length}}">
        <view class="summary-badge overdue" wx:if="{{overdueCount}}">
          <text class="summary-count">{{overdueCount}}</text>
          <text class="summary-label">已逾期</text>
        </view>
        <view class="summary-badge upcoming" wx:if="{{upcomingCount}}">
          <text class="summary-count">{{upcomingCount}}</text>
          <text class="summary-label">即将接种</text>
        </view>
      </view>
    </view>
    <view class="header-actions">
      <view class="generate-btn" bindtap="generateSchedule">
        <text class="generate-btn-text">生成计划</text>
      </view>
      <view class="add-btn" bindtap="goToAdd">
        <text class="add-btn-text">+ 新增</text>
      </view>
    </view>
  </view>

  <view class="vaccine-list" wx:if="{{vaccines.length}}">
    <view class="vaccine-card" wx:for="{{vaccines}}" wx:key="id" data-id="{{item.id}}" bindtap="goToEdit">
      <view class="card-header">
        <text class="vaccine-name">{{item.vaccine_name}}</text>
        <view class="status-tag {{getStatusClass(item.status)}}">
          <text>{{getStatusLabel(item.status)}}</text>
        </view>
      </view>
      <view class="card-meta">
        <text class="meta">第 {{item.dose}} 剂</text>
        <text class="meta-dot">·</text>
        <text class="meta">计划 {{item.scheduled_date}}</text>
      </view>
      <view class="card-extra" wx:if="{{item.actual_date}}">
        <text class="extra-text">实际接种: {{item.actual_date}}</text>
      </view>
      <view class="card-extra" wx:if="{{item.location}}">
        <text class="extra-text">地点: {{item.location}}</text>
      </view>
      <view class="card-extra" wx:if="{{item.reaction}}">
        <text class="extra-text reaction">反应: {{item.reaction}}</text>
      </view>
    </view>
  </view>

  <empty-state
    wx:else
    title="暂无疫苗记录"
    actionText="添加疫苗记录 +"
    bind:action="goToAdd"
  />

  <ai-fab bind:tap="onAIFabTap" />
</view>
