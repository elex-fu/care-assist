<view class="container">
  <!-- Header -->
  <view class="header" wx:if="{{event}}">
    <view class="header-top">
      <text class="hospital-name">{{event.hospital}}</text>
      <view class="status-tag {{event.status}}">
        <text>{{event.status === 'active' ? '住院中' : '已出院'}}</text>
      </view>
    </view>
    <text class="department" wx:if="{{event.department}}">{{event.department}}</text>
    <view class="header-meta">
      <text class="meta">入院 {{event.admission_date}}</text>
      <text class="meta-dot">·</text>
      <text class="meta-days" wx:if="{{event.status === 'active'}}">住院第 {{computeDays()}} 天</text>
      <text class="meta" wx:if="{{event.status === 'discharged' && event.discharge_date}}">出院 {{event.discharge_date}}</text>
    </view>
    <text class="diagnosis" wx:if="{{event.diagnosis}}">诊断: {{event.diagnosis}}</text>
    <text class="doctor" wx:if="{{event.doctor}}">主治医生: {{event.doctor}}</text>
  </view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'daily' ? 'active' : ''}}" data-tab="daily" bindtap="switchTab">
      <text>每天的情况</text>
    </view>
    <view class="tab {{activeTab === 'watch' ? 'active' : ''}}" data-tab="watch" bindtap="switchTab">
      <text>关键指标</text>
    </view>
    <view class="tab {{activeTab === 'compare' ? 'active' : ''}}" data-tab="compare" bindtap="switchTab">
      <text>对比变化</text>
    </view>
  </view>

  <!-- Daily Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'daily'}}">
    <view class="timeline" wx:if="{{dailyEvents.length}}">
      <view class="timeline-item" wx:for="{{dailyEvents}}" wx:key="id">
        <view class="timeline-node"></view>
        <view class="timeline-card">
          <view class="timeline-header">
            <text class="timeline-type">{{item.type === 'visit' ? '就诊' : item.type === 'lab' ? '检验' : item.type === 'medication' ? '用药' : item.type === 'symptom' ? '症状' : item.type === 'hospital' ? '住院' : item.type === 'vaccine' ? '疫苗' : item.type === 'checkup' ? '体检' : item.type === 'milestone' ? '里程碑' : '事件'}}</text>
            <text class="timeline-date">{{item.event_date}}</text>
          </view>
          <text class="timeline-hospital" wx:if="{{item.hospital}}">{{item.hospital}}</text>
          <text class="timeline-diagnosis" wx:if="{{item.diagnosis}}">{{item.diagnosis}}</text>
          <text class="timeline-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-title">暂无每日记录</text>
      <text class="empty-subtitle">时间轴事件会自动展示在这里</text>
    </view>
  </view>

  <!-- Watch Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'watch'}}">
    <view class="indicator-grid" wx:if="{{watchIndicators.length}}">
      <view class="indicator-card" wx:for="{{watchIndicators}}" wx:key="indicator_key">
        <text class="card-name">{{item.indicator_name}}</text>
        <view class="card-value-row">
          <text class="card-value">{{item.value}}</text>
          <text class="card-unit">{{item.unit}}</text>
        </view>
        <view class="card-status" style="background: {{getStatusColor(item.status)}};">
          <text>{{item.status === 'normal' ? '正常' : item.status === 'low' ? '偏低' : item.status === 'high' ? '偏高' : '建议复查'}}</text>
        </view>
        <text class="card-date">{{item.record_date}} {{item.record_time || ''}}</text>
        <view class="card-change" wx:if="{{item.change !== null && item.change !== undefined}}">
          <text class="change-text {{item.change > 0 ? 'up' : item.change < 0 ? 'down' : ''}}">
            {{item.change > 0 ? '↑' : item.change < 0 ? '↓' : '→'}} {{item.change}} {{item.unit}}
          </text>
          <text class="change-percent" wx:if="{{item.change_percent !== null && item.change_percent !== undefined}}">
            ({{item.change_percent > 0 ? '+' : ''}}{{item.change_percent}}%)
          </text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-title">暂无盯盘指标</text>
      <text class="empty-subtitle">在「对比变化」Tab查看趋势</text>
    </view>
  </view>

  <!-- Compare Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'compare'}}">
    <view wx:if="{{compareData}}">
      <view class="compare-summary">
        <view class="summary-row">
          <text class="summary-date">今天 {{compareData.today}}</text>
          <text class="summary-vs">vs</text>
          <text class="summary-date">昨天 {{compareData.yesterday}}</text>
        </view>
        <view class="summary-stats">
          <view class="stat-item">
            <text class="stat-num improve">{{compareData.improved || 0}}</text>
            <text class="stat-label">改善</text>
          </view>
          <view class="stat-item">
            <text class="stat-num worsen">{{compareData.worsened || 0}}</text>
            <text class="stat-label">恶化</text>
          </view>
          <view class="stat-item">
            <text class="stat-num stable">{{compareData.stable || 0}}</text>
            <text class="stat-label">平稳</text>
          </view>
        </view>
      </view>

      <view class="compare-list" wx:if="{{compareData.indicators && compareData.indicators.length}}">
        <view class="compare-row" wx:for="{{compareData.indicators}}" wx:key="indicator_key">
          <view class="compare-name">{{item.indicator_name}}</view>
          <view class="compare-values">
            <text class="compare-today">{{item.today}}</text>
            <text class="compare-unit">{{item.unit}}</text>
          </view>
          <view class="compare-change">
            <text class="change-badge {{item.evaluation === '好转' ? 'improve' : item.evaluation === '变差了' ? 'worsen' : 'stable'}}">
              {{item.change > 0 ? '+' : ''}}{{item.change}} {{item.unit}}
            </text>
            <text class="change-eval">{{item.evaluation}}</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{!compareData.indicators || !compareData.indicators.length}}">
        <text class="empty-title">暂无对比数据</text>
        <text class="empty-subtitle">需要连续两天的指标记录</text>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-title">暂无对比数据</text>
      <text class="empty-subtitle">需要连续两天的指标记录</text>
    </view>
  </view>

  <!-- Discharge Button -->
  <view class="footer-actions" wx:if="{{event && event.status === 'active'}}">
    <view class="discharge-btn" bindtap="discharge">
      <text>办理出院</text>
    </view>
  </view>
</view>
